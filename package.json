{
  "name": "poker-notes",
  "private": true,
  "scripts": {
    "start": "meteor run",
    "build": "meteor build ./build --directory && cd ./build/bundle/programs/server && npm install --omit=dev",
    "zip": "./scripts/zip.sh",
    "prod": "./scripts/run-prod.sh",
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "test-app": "TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
    "visualize": "meteor --production --extra-packages bundle-visualizer",
    "type-check": "vue-tsc --noEmit",
    "type-check:watch": "vue-tsc --noEmit --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@swc/helpers": "^0.5.21",
    "@vueuse/core": "^14.3.0",
    "date-fns": "^4.1.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.18.1",
    "meteor-node-stubs": "^1.2.27",
    "meteor-vite": "^3.9.0-beta.2",
    "patch-package": "^8.0.1",
    "poker-odds-calc": "^0.0.14",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-meteor-tracker": "^3.0.0-beta.7",
    "vue-router": "^5.0.6"
  },
  "meteor": {
    "modern": true,
    "mainModule": {
      "client": "client/entry-meteor-client.ts",
      "server": "server/entry-meteor-server.ts"
    },
    "testModule": "tests/main.ts"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/meteor": "^2.9.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "prettier": "^3.8.3",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vue-tsc": "^3.2.8"
  }
}
